<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.poyangreportbackend.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.example.poyangreportbackend.domain.User">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="username" column="username" jdbcType="VARCHAR"/>
            <result property="avatar" column="avatar" jdbcType="VARCHAR"/>
            <result property="phone" column="phone" jdbcType="VARCHAR"/>
            <result property="role" column="role" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="isDel" column="is_del" jdbcType="INTEGER"/>
            <result property="isAuth" column="is_auth" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,username,avatar,
        phone,role,create_time,
        is_del,is_auth
    </sql>
</mapper>
